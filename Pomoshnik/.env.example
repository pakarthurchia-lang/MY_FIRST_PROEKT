# Получи токен у @BotFather в Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Данные входа на сайт воды
WATER_LOGIN=your_email@example.com
WATER_PASSWORD=your_password_here

# Город доставки (уже заполнен)
WATER_CITY=Ростов-на-Дону

# Запустить браузер в видимом режиме для отладки (true/false)
WATER_HEADLESS=true
